{
  "name": "nuntly-sdk-typescript",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "cd packages/sdk && bun run build",
    "typecheck": "cd packages/sdk && bun run typecheck",
    "test": "cd packages/sdk && bun run test",
    "clean": "cd packages/sdk && bun run clean"
  }
}
